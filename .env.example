# Copy to `.env` or `.env.local` and uncomment ONE pattern.

# Local dev + Vite proxy → http://127.0.0.1:8000 (default when variable is unset):
# VITE_API_BASE_URL=

# Local or deployed frontend calling Render directly (enable CORS on the API):
# VITE_API_BASE_URL=https://rural-teacher-backend.onrender.com

# Optional — proxy target when VITE_API_BASE_URL is empty (npm run dev):
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
